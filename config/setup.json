    "debater_a_skill": "evidence_based",
    "debater_b_skill": "socratic",
    "debater_pool": [
      "RepetitionGuardSkill",
      "RebuttalSkill",
      "ProgressionSkill",
      "EvidenceSkill",
      "SocraticSkill",
      "SummarizationSkill",
      "CitationSkill",
      "ToneModerationSkill"
