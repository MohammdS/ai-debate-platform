    "stance_b": "AI is not a threat",
    "menu_stance_a": "Yes, strongly agree",
    "menu_stance_b": "No, strongly disagree"
  },
  "providers": {
    "available": ["groq", "gemini", "openai", "zai", "openrouter", "mock"],
    "labels": {
      "groq": "Groq",
      "gemini": "Gemini",
      "openai": "OpenAI",
      "zai": "Z.ai",
      "openrouter": "OpenRouter",
      "mock": "Mock"
    }
