    "debater_max_words": 130,
    "judge_max_words": 200,
    "judge_max_transcript_entries": 20
  },
  "defaults": {
    "provider_a": "zai",
    "provider_b": "groq",
    "judge_provider": "groq",
    "topic": "Is AI a threat?",
